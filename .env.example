# Required — Supabase credentials
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required — Site URL (used in OG tags, canonical links, sitemap)
VITE_SITE_URL=https://your-production-domain.com

# Optional — Error tracking (Sentry)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Supabase Edge Function secrets (set via CLI, not in .env):
# supabase secrets set CORS_ORIGIN=https://your-production-domain.com
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set DEEPSEEK_API_KEY=sk-...
# supabase secrets set CRON_SECRET=your-cron-secret
# supabase secrets set SENDGRID_API_KEY=SG...
